{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "task_id", "reference_baseline", "execution_baseline", "capability_id", "site", "status", "stage", "result_quality", "requested_count", "collected_count", "access", "strategy_used", "fallback_reason", "limits", "artifacts", "warnings", "failure", "progress", "started_at", "updated_at", "finished_at", "ok", "needs_user_action", "reason_code"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string"},
    "task_id": {"type": "string"},
    "reference_baseline": {"type": "string"},
    "execution_baseline": {"type": "string"},
    "capability_id": {"type": "string"},
    "site": {"type": "string"},
    "status": {"type": "string"},
    "stage": {"type": "string"},
    "result_quality": {"type": "string"},
    "requested_count": {"type": "integer", "minimum": 0},
    "collected_count": {"type": "integer", "minimum": 0},
    "access": {"type": "string"},
    "strategy_used": {"type": "string"},
    "fallback_reason": {"type": ["string", "null"]},
    "limits": {"type": "object"},
    "artifacts": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "failure": {"type": ["object", "null"]},
    "progress": {"type": "object"},
    "started_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "finished_at": {"type": "string"},
    "ok": {"type": "boolean"},
    "needs_user_action": {"type": "boolean"},
    "reason_code": {"type": ["string", "null"]}
  }
}
